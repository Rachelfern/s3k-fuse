# =============================================================================
# Environment variables — copy to .env.local and fill in real values.
# NEVER commit .env.local or real secrets to git.
# =============================================================================

# --- Supabase ---
#
# PUBLIC (safe for the browser — Next.js inlines NEXT_PUBLIC_* at build time):
#   NEXT_PUBLIC_SUPABASE_URL      — project API URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY   — anon/public key (RLS-protected)
#
# SERVER-ONLY (API routes, server components, scripts — never NEXT_PUBLIC_):
#   SUPABASE_SERVICE_ROLE_KEY       — bypasses RLS; keep secret, server-side only
#
# Do NOT create NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY — service role keys must
# never be exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Ollama (legacy /api/chat commerce agent — optional local dev)
NEXT_PUBLIC_OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# Groq (customer chat recommendations & conversational replies)
# Set USE_GROQ=false to bypass the API and use deterministic fallbacks (dev/testing)
USE_GROQ=false
GROQ_API_KEY=
# Optional overrides (defaults shown)
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
